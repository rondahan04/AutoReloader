{
  "manifest_version": 3,
  "name": "Auto Reloader for RUNI",
  "version": "1.0.0",
  "description": "Automatically refreshes RUNI and Moodle pages every 10 minutes to keep sessions alive",
  "permissions": [
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://my.runi.ac.il/*",
    "https://moodle.runi.ac.il/*",
    "https://yedion.runi.ac.il/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}

