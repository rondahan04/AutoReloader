{
  "manifest_version": 3,
  "name": "SessionAlive",
  "version": "3.0.0",
  "description": "Ghost pings keep your portals alive — silent, smart, and always connected.",
  "permissions": [
    "alarms",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://login.microsoftonline.com/*",
        "https://login.microsoft.com/*",
        "https://my.runi.ac.il/*",
        "https://moodle.runi.ac.il/*",
        "https://yedion.runi.ac.il/*"
      ],
      "js": ["sso-recovery.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
